# 环境变量配置
# 复制此文件为 .env 并填入实际值

# --- AI 模型配置 ---

# DeepSeek 配置
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MODEL_PROVIDER=deepseek

# 火山引擎/豆包配置
VISION_API_KEY=your-vision-api-key
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_MODEL=doubao-seed-1-6-vision-250815
VISION_TEXT_MODEL=doubao-seed-2-0-lite-260215

# OpenAI 兼容配置（可选）
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- PDF 解析配置 ---

# 是否开启 PDF 多模态解析（需要 VISION_API_KEY）
ENABLE_PDF_MULTIMODAL=false

# PDF 解析模式：single（整个文档）或 page（按页）
PDF_MODE=single

# PDF 表格解析策略
PDF_TABLE_STRATEGY=lines

# 是否提取 PDF 图像（需开启 ENABLE_PDF_MULTIMODAL）
PDF_EXTRACT_IMAGES=false

# PDF 解析器最大缓存条目数
PDF_MAX_CACHE_SIZE=128

# --- 安全配置 ---

# API 认证密钥（留空则不启用认证）
API_KEY=

# 允许的 CORS 来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# 每 IP 每分钟速率限制
RATE_LIMIT_PER_MINUTE=60

# --- 服务器配置 ---

# 服务器端口
SERVER_PORT=2026

# --- 日志配置 ---

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Qwen (通义千问) 配置
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-35b-a3b
