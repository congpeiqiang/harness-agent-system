# ============================================================
# AI 模型配置
# ============================================================

# DeepSeek 配置
DEEPSEEK_API_KEY=sk-9e0e849da2b5495e90b38cf302235cf3
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_MAX_INPUT_TOKENS=120000

# 视觉模型 (Vision) / 豆包配置
VISION_API_KEY=ark-e8825f80-b0bf-422d-a895-9973de6856b3-c2c33
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_MODEL=doubao-seed-1-6-vision-250815
VISION_TEXT_MODEL=doubao-seed-2-0-lite-260215

# OpenAI 配置 (兼容格式)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ============================================================
# PDF 解析器配置
# ============================================================

# 是否开启 PDF 多模态解析（图像识别）
ENABLE_PDF_MULTIMODAL=false

# PDF 解析模式，可选值: single, page
PDF_MODE=single

# PDF 表格解析策略，可选值: lines, text 等
PDF_TABLE_STRATEGY=lines

# 是否提取 PDF 图像（仅 ENABLE_PDF_MULTIMODAL=true 时生效）
PDF_EXTRACT_IMAGES=false

# PDF 解析器最大缓存条目数
PDF_MAX_CACHE_SIZE=128

# ============================================================
# 日志配置
# ============================================================

# 日志级别，可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================
# Langsmith
# ============================================================
LANGSMITH_TRACING = true
LANGSMITH_API_KEY = "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"
LANGSMITH_PROJECT = "langchain-1.0-example"