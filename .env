# ============================================================
# PDF 解析器配置
# ============================================================
# 是否开启 PDF 多模态解析（图像识别）
ENABLE_PDF_MULTIMODAL=false
# PDF 解析模式，可选值: single, page
PDF_MODE=single
# PDF 表格解析策略，可选值: lines, text 等
PDF_TABLE_STRATEGY=lines
# 是否提取 PDF 图像（仅 ENABLE_PDF_MULTIMODAL=true 时生效）
PDF_EXTRACT_IMAGES=false
# PDF 解析器最大缓存条目数
PDF_MAX_CACHE_SIZE=128

# ============================================================
# 日志配置
# ============================================================
# 日志级别，可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
